{
  "redirects": [
    {
      "source": "/:path((?!api/).*)",
      "has": [
        {
          "type": "host",
          "value": "shifree.vercel.app"
        }
      ],
      "destination": "https://shifree.com/:path*",
      "permanent": false
    }
  ],
  "rewrites": [
    { "source": "/(.*)", "destination": "/api/index" }
  ],
  "crons": [
    {
      "path": "/api/cron/process-tasks",
      "schedule": "0 9 * * *"
    }
  ]
}
